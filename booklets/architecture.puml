@startuml
skinparam componentStyle rectangle

' External components
component "Simulator" as sim #line.dashed

' Microservices
component "Ingestion\nService" as ing
component "Processing\nService" as proc
component "State\nService" as state
component "Rule\nService" as rule
component "Actuator\nService" as act
component "Frontend" as fe

' Infrastructure
queue "Kafka" as kafka
database "MongoDB" as mongo
database "PostgreSQL" as postgres
component "Nginx\nGateway" as nginx

' Data flow from simulator to ingestion
sim -[#228B22]right-> ing : <color:#228B22>[REST]</color>\nPoll sensor data

' Ingestion publishes raw data to Kafka
ing -[#6B3E26]down-> kafka : <color:#6B3E26>[KAFKA]</color>\nPublish raw sensors\n(mars.raw.sensors)

' Processing consumes raw data, normalizes, applies rules
kafka -[#6B3E26]right-> proc : <color:#6B3E26>[KAFKA]</color>\nConsume raw sensors
proc -[#6B3E26]down-> kafka : <color:#6B3E26>[KAFKA]</color>\nPublish normalized events\n(mars.normalized.events)
proc -[#6B3E26]down-> kafka : <color:#6B3E26>[KAFKA]</color>\nPublish actuator commands\n(mars.actuator.commands)

' Processing interacts with MongoDB for rules
proc -[#B22222]right-> mongo : <color:#B22222>[MongoDB]</color>\nRead automation rules
mongo -[#B22222]left-> proc : <color:#B22222>[MongoDB]</color>\nStore processed data

' State service consumes normalized events
kafka -[#6B3E26]up-> state : <color:#6B3E26>[KAFKA]</color>\nConsume normalized events

' Rule service manages rules in MongoDB
rule -[#B22222]down-> mongo : <color:#B22222>[MongoDB]</color>\nCRUD automation rules

' Actuator service consumes commands and controls simulator
kafka -[#6B3E26]right-> act : <color:#6B3E26>[KAFKA]</color>\nConsume actuator commands
act -[#228B22]up-> sim : <color:#228B22>[REST]</color>\nSend actuator commands

' Frontend interactions
fe -[#228B22]down-> state : <color:#228B22>[REST]</color>\nFetch device states
state -[#800080]up-> fe : <color:#800080>[SSE]</color>\nPush state updates

fe -[#228B22]right-> rule : <color:#228B22>[REST]</color>\nManage automation rules

fe -[#228B22]up-> act : <color:#228B22>[REST]</color>\nManual actuator control

' Nginx gateway
nginx -[#000000]down-> fe : <color:#000000>[HTTP]</color>\nServe frontend
nginx -[#000000]down-> state : <color:#000000>[HTTP]</color>\nRoute /api/state/*
nginx -[#000000]down-> rule : <color:#000000>[HTTP]</color>\nRoute /api/rules/*
nginx -[#000000]down-> act : <color:#000000>[HTTP]</color>\nRoute /api/actuators/*

' PostgreSQL for structured data (from schema)
proc -[#B22222]right-> postgres : <color:#B22222>[PostgreSQL]</color>\nStore sensor readings
state -[#B22222]up-> postgres : <color:#B22222>[PostgreSQL]</color>\nPersist device states
rule -[#B22222]left-> postgres : <color:#B22222>[PostgreSQL]</color>\nStore rule executions

@enduml
